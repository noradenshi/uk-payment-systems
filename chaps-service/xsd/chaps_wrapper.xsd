           xmlns:h4="urn:iso:std:iso:20022:tech:xsd:head.001.001.04"
           elementFormDefault="qualified">

    <xs:import namespace="urn:iso:std:iso:20022:tech:xsd:head.001.001.02" schemaLocation="head.001.001.02.xsd"/>
    <xs:import namespace="urn:iso:std:iso:20022:tech:xsd:head.001.001.04" schemaLocation="head.001.001.04.xsd"/>

    <xs:import namespace="urn:iso:std:iso:20022:tech:xsd:pacs.008.001.14" schemaLocation="pacs.008.001.14.xsd"/>
    <xs:import namespace="urn:iso:std:iso:20022:tech:xsd:pacs.002.001.16" schemaLocation="pacs.002.001.16.xsd"/>

    <xs:element name="BizMsg">
